<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <ProjectGuid>{A1B2C3D4-0002-0002-0002-000000000002}</ProjectGuid>
    <RootNamespace>EwPresenterNet</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
    <CLRSupport>NetCore</CLRSupport>
    <TargetFramework>net8.0-windows10.0.26100.0</TargetFramework>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Label="Configuration" Condition="'$(Configuration)'=='Debug'">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>true</UseDebugLibraries>
    <PlatformToolset>v143</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <PropertyGroup Label="Configuration" Condition="'$(Configuration)'=='Release'">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v143</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
    <!-- WholeProgramOptimization (/LTCG) is ineffective for C++/CLI DLLs and
         causes a spurious linker performance note; omitted intentionally. -->
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <PropertyGroup Label="UserMacros" />

  <PropertyGroup>
    <OutDir>$(SolutionDir)..\..\..\build\bin\$(Configuration)\</OutDir>
    <IntDir>$(SolutionDir)obj\$(Platform)\$(Configuration)\ewpresenter.net\</IntDir>
    <EwCalcBuildRoot>$(SolutionDir)..\..\..\build</EwCalcBuildRoot>
    <EwCalcSrcRoot>$(SolutionDir)..\..\..\</EwCalcSrcRoot>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <WarningLevel>Level4</WarningLevel>
      <!-- C4679: C++/CLI cannot import static virtual interface members added
           to System::IntPtr and System::String in .NET 7+. Unused here. -->
      <DisableSpecificWarnings>4679</DisableSpecificWarnings>
      <LanguageStandard>stdcpp20</LanguageStandard>
      <AdditionalIncludeDirectories>
        $(EwCalcSrcRoot)libew\include;
        $(EwCalcSrcRoot)ewpresenter\include;
        %(AdditionalIncludeDirectories)
      </AdditionalIncludeDirectories>
      <PreprocessorDefinitions>WIN32;_WINDOWS;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <ExceptionHandling>Async</ExceptionHandling>
    </ClCompile>
    <Link>
      <AdditionalLibraryDirectories>
        $(EwCalcBuildRoot)\lib\$(Configuration);
        %(AdditionalLibraryDirectories)
      </AdditionalLibraryDirectories>
      <AdditionalDependencies>libew.lib;ewpresenter.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)'=='Debug'">
    <ClCompile>
      <Optimization>Disabled</Optimization>
      <RuntimeLibrary>MultiThreadedDebugDLL</RuntimeLibrary>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Release'">
    <ClCompile>
      <Optimization>MaxSpeed</Optimization>
      <RuntimeLibrary>MultiThreadedDLL</RuntimeLibrary>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
    </ClCompile>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClCompile Include="PropagationAdapter.cpp" />
    <ClCompile Include="LinkAdapter.cpp" />
    <ClCompile Include="ReceiverAdapter.cpp" />
    <ClCompile Include="JammingAdapter.cpp" />
    <ClCompile Include="LocationAdapter.cpp" />
    <ClCompile Include="RadarAdapter.cpp" />
    <ClCompile Include="DigitalAdapter.cpp" />
    <ClCompile Include="AntennaAdapter.cpp" />
  </ItemGroup>

  <ItemGroup>
    <ClInclude Include="NativeCallbacks.h" />
    <ClInclude Include="MarshalHelper.h" />
    <ClInclude Include="PropagationAdapter.h" />
    <ClInclude Include="LinkAdapter.h" />
    <ClInclude Include="ReceiverAdapter.h" />
    <ClInclude Include="JammingAdapter.h" />
    <ClInclude Include="LocationAdapter.h" />
    <ClInclude Include="RadarAdapter.h" />
    <ClInclude Include="DigitalAdapter.h" />
    <ClInclude Include="AntennaAdapter.h" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />

</Project>
