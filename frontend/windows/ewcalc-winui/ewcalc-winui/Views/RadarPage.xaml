<Page
    x:Class="EwCalc.Views.RadarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EwCalc.Views">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24" Spacing="8">

            <StackPanel Margin="0,0,0,8">
                <TextBlock Text="Radar" Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock Text="Range equation · Pulse compression · Coherent integration gain"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <TextBlock Text="RADAR PARAMETERS" Style="{StaticResource SectionHeaderStyle}" />
            <Border Style="{StaticResource InputCardStyle}">
                <StackPanel Spacing="12">
                    <NumberBox x:Name="TxPowerBox"   Header="Tx power (dBm)"
                               Value="{x:Bind ViewModel.DefaultTxPower, Mode=OneTime}"
                               Minimum="-50" Maximum="200"
                               SpinButtonPlacementMode="Compact" SmallChange="1"
                               ValueChanged="TxPowerBox_ValueChanged" />
                    <NumberBox x:Name="GainBox"      Header="Antenna gain (dBi)"
                               Value="{x:Bind ViewModel.DefaultAntennaGain, Mode=OneTime}"
                               Minimum="-30" Maximum="60"
                               SpinButtonPlacementMode="Compact" SmallChange="0.5"
                               ValueChanged="GainBox_ValueChanged" />
                    <NumberBox x:Name="FrequencyBox" Header="Frequency (MHz)"
                               Value="{x:Bind ViewModel.DefaultFrequency, Mode=OneTime}"
                               Minimum="1" Maximum="100000"
                               SpinButtonPlacementMode="Compact" SmallChange="100"
                               ValueChanged="FrequencyBox_ValueChanged" />
                    <NumberBox x:Name="RcsBox"       Header="Target RCS (dBsm)"
                               Value="{x:Bind ViewModel.DefaultTargetRcs, Mode=OneTime}"
                               Minimum="-40" Maximum="60"
                               SpinButtonPlacementMode="Compact" SmallChange="1"
                               ValueChanged="RcsBox_ValueChanged" />
                    <NumberBox x:Name="LossBox"      Header="System losses (dB)"
                               Value="{x:Bind ViewModel.DefaultSystemLosses, Mode=OneTime}"
                               Minimum="0" Maximum="30"
                               SpinButtonPlacementMode="Compact" SmallChange="0.5"
                               ValueChanged="LossBox_ValueChanged" />
                </StackPanel>
            </Border>

            <TextBlock Text="RECEIVER" Style="{StaticResource SectionHeaderStyle}" />
            <Border Style="{StaticResource InputCardStyle}">
                <StackPanel Spacing="12">
                    <NumberBox x:Name="NfBox"  Header="Noise figure (dB)"
                               Value="{x:Bind ViewModel.DefaultNoiseFigure, Mode=OneTime}"
                               Minimum="0" Maximum="30"
                               SpinButtonPlacementMode="Compact" SmallChange="0.5"
                               ValueChanged="NfBox_ValueChanged" />
                    <NumberBox x:Name="BwBox"  Header="Bandwidth (MHz)"
                               Value="{x:Bind ViewModel.DefaultBandwidth, Mode=OneTime}"
                               Minimum="0.001" Maximum="10000"
                               SpinButtonPlacementMode="Compact" SmallChange="0.1"
                               ValueChanged="BwBox_ValueChanged" />
                    <NumberBox x:Name="SnrBox" Header="Required SNR (dB)"
                               Value="{x:Bind ViewModel.DefaultRequiredSnr, Mode=OneTime}"
                               Minimum="-10" Maximum="50"
                               SpinButtonPlacementMode="Compact" SmallChange="0.5"
                               ValueChanged="SnrBox_ValueChanged" />
                </StackPanel>
            </Border>

            <TextBlock Text="SIGNAL PROCESSING" Style="{StaticResource SectionHeaderStyle}" />
            <Border Style="{StaticResource InputCardStyle}">
                <StackPanel Spacing="12">
                    <NumberBox x:Name="TbProductBox" Header="Time-BW product"
                               Value="{x:Bind ViewModel.DefaultTimeBandwidthProd, Mode=OneTime}"
                               Minimum="1" Maximum="1000000"
                               SpinButtonPlacementMode="Compact" SmallChange="10"
                               ValueChanged="TbProductBox_ValueChanged" />
                    <NumberBox x:Name="NumPulsesBox" Header="Coherent pulses"
                               Value="{x:Bind ViewModel.DefaultNumPulses, Mode=OneTime}"
                               Minimum="1" Maximum="100000"
                               SpinButtonPlacementMode="Compact" SmallChange="1"
                               ValueChanged="NumPulsesBox_ValueChanged" />
                </StackPanel>
            </Border>

            <TextBlock Text="RANGE EQUATION" Style="{StaticResource SectionHeaderStyle}" />
            <Border Style="{StaticResource ResultCardStyle}">
                <StackPanel Spacing="0">
                    <local:ResultRow Label="Max range"    Value="{x:Bind ViewModel.MaxRange,   Mode=OneWay}" IsHighlighted="True" />
                    <local:ResultRow Label="Two-way loss" Value="{x:Bind ViewModel.TwoWayLoss, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <TextBlock Text="SIGNAL PROCESSING GAIN" Style="{StaticResource SectionHeaderStyle}" />
            <Border Style="{StaticResource ResultCardStyle}">
                <StackPanel Spacing="0">
                    <local:ResultRow Label="Pulse compression gain"    Value="{x:Bind ViewModel.PcGain,  Mode=OneWay}" />
                    <local:ResultRow Label="Coherent integration gain" Value="{x:Bind ViewModel.CohGain, Mode=OneWay}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
