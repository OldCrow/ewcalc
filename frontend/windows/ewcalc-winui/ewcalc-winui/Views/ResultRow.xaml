<UserControl
    x:Class="EwCalc.Views.ResultRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid MinHeight="36" Padding="0,4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" x:Name="LabelBlock"
                   Style="{StaticResource ResultLabelStyle}"
                   VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" x:Name="ValueBlock"
                   Style="{StaticResource ResultValueStyle}"
                   VerticalAlignment="Center"
                   TextAlignment="Right" />
    </Grid>
</UserControl>
