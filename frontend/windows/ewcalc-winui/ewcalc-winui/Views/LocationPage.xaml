<Page
    x:Class="EwCalc.Views.LocationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EwCalc.Views">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24" Spacing="8">

            <StackPanel Margin="0,0,0,8">
                <TextBlock Text="Emitter location" Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock Text="CEP from AOA bearing error · TDOA timing · EEP semi-axes"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <TextBlock Text="AOA METHOD" Style="{StaticResource SectionHeaderStyle}" />
            <Border Style="{StaticResource InputCardStyle}">
                <StackPanel Spacing="12">
                    <NumberBox x:Name="BearingErrorBox" Header="RMS bearing error (°)"
                               Value="{x:Bind ViewModel.DefaultRmsBearingError, Mode=OneTime}"
                               Minimum="0.01" Maximum="45"
                               SpinButtonPlacementMode="Compact" SmallChange="0.1"
                               ValueChanged="BearingErrorBox_ValueChanged" />
                    <NumberBox x:Name="AoaRangeBox"     Header="Range to emitter (km)"
                               Value="{x:Bind ViewModel.DefaultAoaRange, Mode=OneTime}"
                               Minimum="0.1" Maximum="10000"
                               SpinButtonPlacementMode="Compact" SmallChange="1"
                               ValueChanged="AoaRangeBox_ValueChanged" />
                </StackPanel>
            </Border>

            <TextBlock Text="TDOA METHOD" Style="{StaticResource SectionHeaderStyle}" />
            <Border Style="{StaticResource InputCardStyle}">
                <StackPanel Spacing="12">
                    <NumberBox x:Name="RmsTimeErrorBox" Header="RMS timing error (ns)"
                               Value="{x:Bind ViewModel.DefaultRmsTimeError, Mode=OneTime}"
                               Minimum="0.001" Maximum="100000"
                               SpinButtonPlacementMode="Compact" SmallChange="1"
                               ValueChanged="RmsTimeErrorBox_ValueChanged" />
                    <NumberBox x:Name="BaselineBox" Header="Receiver baseline (km)"
                               Value="{x:Bind ViewModel.DefaultBaseline, Mode=OneTime}"
                               Minimum="0.1" Maximum="10000"
                               SpinButtonPlacementMode="Compact" SmallChange="1"
                               ValueChanged="BaselineBox_ValueChanged" />
                </StackPanel>
            </Border>

            <TextBlock Text="EEP METHOD" Style="{StaticResource SectionHeaderStyle}" />
            <Border Style="{StaticResource InputCardStyle}">
                <StackPanel Spacing="12">
                    <NumberBox x:Name="SemiMajorBox" Header="Semi-major axis (km, 1σ)"
                               Value="{x:Bind ViewModel.DefaultSemiMajor, Mode=OneTime}"
                               Minimum="0.001" Maximum="1000"
                               SpinButtonPlacementMode="Compact" SmallChange="0.1"
                               ValueChanged="SemiMajorBox_ValueChanged" />
                    <NumberBox x:Name="SemiMinorBox" Header="Semi-minor axis (km, 1σ)"
                               Value="{x:Bind ViewModel.DefaultSemiMinor, Mode=OneTime}"
                               Minimum="0.001" Maximum="1000"
                               SpinButtonPlacementMode="Compact" SmallChange="0.1"
                               ValueChanged="SemiMinorBox_ValueChanged" />
                </StackPanel>
            </Border>

            <TextBlock Text="RESULTS" Style="{StaticResource SectionHeaderStyle}" />
            <Border Style="{StaticResource ResultCardStyle}">
                <StackPanel Spacing="0">
                    <local:ResultRow Label="CEP (AOA method)"  Value="{x:Bind ViewModel.CepAoa,  Mode=OneWay}" IsHighlighted="True" />
                    <local:ResultRow Label="CEP (TDOA)"        Value="{x:Bind ViewModel.CepTdoa, Mode=OneWay}" IsHighlighted="True" />
                    <local:ResultRow Label="CEP (EEP method)"  Value="{x:Bind ViewModel.CepEep,  Mode=OneWay}" IsHighlighted="True" />
                </StackPanel>
            </Border>
            <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                     Title="About CEP"
                     Message="The 50% circular error probable is the radius within which 50% of location estimates fall." />

        </StackPanel>
    </ScrollViewer>
</Page>
